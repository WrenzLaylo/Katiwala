// Katiwala — Prisma Schema
// Database: PostgreSQL via Supabase
// Run: npx prisma migrate dev --name init

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  CUSTOMER
  TRADESMAN
  ADMIN
  DISPATCHER

  @@schema("public")
}

enum AccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED

  @@schema("public")
}

enum TradesmanStatus {
  PENDING_VERIFICATION
  VERIFIED
  SUSPENDED

  @@schema("public")
}

enum TradesmanAvailability {
  AVAILABLE
  BUSY
  OFFLINE

  @@schema("public")
}

enum BookingStatus {
  PENDING
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED

  @@schema("public")
}

enum PaymentMethod {
  GCASH
  MAYA
  CREDIT_CARD
  CASH

  @@schema("public")
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED

  @@schema("public")
}

enum SubscriptionPlan {
  CUSTOMER_BASIC
  TRADESMAN_PRO

  @@schema("public")
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED

  @@schema("public")
}

enum ServiceCategory {
  ELECTRICAL
  PLUMBING
  CARPENTRY
  PAINTING
  WELDING
  AIRCON
  APPLIANCE_REPAIR
  ROOFING
  MASONRY
  TILE_INSTALLATION
  TINTING
  GATES
  GARAGE_DOORS
  HOME_AUTOMATION
  HOME_SECURITY
  CCTV
  SOLAR
  SMART_HOME
  RENOVATION
  CLEANING
  HANDYMAN

  @@schema("public")
}

enum DocumentType {
  GOVERNMENT_ID
  NBI_CLEARANCE
  TESDA_CERTIFICATE
  BARANGAY_CLEARANCE
  PROFILE_PHOTO
  CERTIFICATION

  @@schema("public")
}

// ============================================================
// CORE USER
// ============================================================

model User {
  id           String        @id @default(uuid())
  phone        String        @unique
  email        String?       @unique
  passwordHash String?
  role         UserRole      @default(CUSTOMER)
  status       AccountStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  customerProfile  CustomerProfile?
  tradesmanProfile TradesmanProfile?
  adminProfile     AdminProfile?
  notifications    Notification[]
  fcmTokens        FcmToken[]

  @@map("users")
  @@schema("public")
}

model FcmToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  device    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("fcm_tokens")
  @@schema("public")
}

// ============================================================
// CUSTOMER
// ============================================================

model CustomerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  firstName String
  lastName  String
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  addresses    Address[]
  bookings     Booking[]
  reviews      Review[]
  subscription Subscription?
  referralCode ReferralCode?

  @@map("customer_profiles")
  @@schema("public")
}

model Address {
  id         String  @id @default(uuid())
  customerId String
  label      String
  street     String
  barangay   String
  city       String
  province   String
  zipCode    String?
  latitude   Float?
  longitude  Float?
  isDefault  Boolean @default(false)

  customer CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("addresses")
  @@schema("public")
}

// ============================================================
// TRADESMAN
// ============================================================

model TradesmanProfile {
  id               String                @id @default(uuid())
  userId           String                @unique
  firstName        String
  lastName         String
  avatarUrl        String?
  bio              String?
  status           TradesmanStatus       @default(PENDING_VERIFICATION)
  availability     TradesmanAvailability @default(OFFLINE)
  currentLatitude  Float?
  currentLongitude Float?
  lastLocationAt   DateTime?
  averageRating    Float                 @default(0)
  totalJobs        Int                   @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills        TradesmanSkill[]
  documents     TradesmanDocument[]
  bookings      Booking[]
  reviews       Review[]
  earnings      Earning[]
  subscription  Subscription?
  payoutAccount PayoutAccount?

  @@map("tradesman_profiles")
  @@schema("public")
}

model TradesmanSkill {
  id          String          @id @default(uuid())
  tradesmanId String
  category    ServiceCategory
  yearsExp    Int             @default(0)
  isVerified  Boolean         @default(false)

  tradesman TradesmanProfile @relation(fields: [tradesmanId], references: [id], onDelete: Cascade)

  @@unique([tradesmanId, category])
  @@map("tradesman_skills")
  @@schema("public")
}

model TradesmanDocument {
  id          String       @id @default(uuid())
  tradesmanId String
  type        DocumentType
  fileUrl     String
  isVerified  Boolean      @default(false)
  verifiedAt  DateTime?
  verifiedBy  String?
  uploadedAt  DateTime     @default(now())

  tradesman TradesmanProfile @relation(fields: [tradesmanId], references: [id], onDelete: Cascade)

  @@map("tradesman_documents")
  @@schema("public")
}

model PayoutAccount {
  id          String   @id @default(uuid())
  tradesmanId String   @unique
  gcashNumber String?
  mayaNumber  String?
  bankName    String?
  bankAccount String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tradesman TradesmanProfile @relation(fields: [tradesmanId], references: [id], onDelete: Cascade)

  @@map("payout_accounts")
  @@schema("public")
}

// ============================================================
// ADMIN
// ============================================================

model AdminProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  firstName String
  lastName  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
  @@schema("public")
}

// ============================================================
// SERVICES
// ============================================================

model Service {
  id          String          @id @default(uuid())
  category    ServiceCategory
  name        String
  description String?
  basePrice   Float
  unit        String
  isActive    Boolean         @default(true)
  imageUrl    String?
  createdAt   DateTime        @default(now())

  bookingItems BookingItem[]

  @@map("services")
  @@schema("public")
}

// ============================================================
// BOOKING
// ============================================================

model Booking {
  id                 String        @id @default(uuid())
  customerId         String
  tradesmanId        String?
  addressId          String
  status             BookingStatus @default(PENDING)
  scheduledAt        DateTime
  startedAt          DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  notes              String?
  totalAmount        Float
  commissionRate     Float         @default(0.25)
  commissionAmount   Float
  tradesmanPayout    Float
  isEmergency        Boolean       @default(false)
  warrantyDays       Int           @default(7)
  warrantyExpiry     DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  customer   CustomerProfile    @relation(fields: [customerId], references: [id])
  tradesman  TradesmanProfile?  @relation(fields: [tradesmanId], references: [id])
  address    Address            @relation(fields: [addressId], references: [id])
  items      BookingItem[]
  photos     BookingPhoto[]
  payment    Payment?
  review     Review?
  statusLogs BookingStatusLog[]
  dispute    Dispute?

  @@map("bookings")
  @@schema("public")
}

model BookingItem {
  id        String @id @default(uuid())
  bookingId String
  serviceId String
  quantity  Int    @default(1)
  unitPrice Float
  subtotal  Float

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@map("booking_items")
  @@schema("public")
}

model BookingPhoto {
  id         String   @id @default(uuid())
  bookingId  String
  url        String
  type       String
  uploadedAt DateTime @default(now())
  uploadedBy String

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_photos")
  @@schema("public")
}

model BookingStatusLog {
  id        String         @id @default(uuid())
  bookingId String
  oldStatus BookingStatus?
  newStatus BookingStatus
  changedBy String
  note      String?
  createdAt DateTime       @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_status_logs")
  @@schema("public")
}

// ============================================================
// PAYMENT
// ============================================================

model Payment {
  id             String        @id @default(uuid())
  bookingId      String        @unique
  amount         Float
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  paymongoId     String?
  paymongoSource String?
  paidAt         DateTime?
  refundedAt     DateTime?
  refundReason   String?
  createdAt      DateTime      @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("payments")
  @@schema("public")
}

model Earning {
  id          String    @id @default(uuid())
  tradesmanId String
  bookingId   String    @unique
  grossAmount Float
  commission  Float
  netAmount   Float
  isPaid      Boolean   @default(false)
  paidAt      DateTime?
  createdAt   DateTime  @default(now())

  tradesman TradesmanProfile @relation(fields: [tradesmanId], references: [id])

  @@map("earnings")
  @@schema("public")
}

// ============================================================
// REVIEWS
// ============================================================

model Review {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  customerId  String
  tradesmanId String
  rating      Int
  comment     String?
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())

  booking   Booking          @relation(fields: [bookingId], references: [id])
  customer  CustomerProfile  @relation(fields: [customerId], references: [id])
  tradesman TradesmanProfile @relation(fields: [tradesmanId], references: [id])

  @@map("reviews")
  @@schema("public")
}

// ============================================================
// DISPUTES
// ============================================================

model Dispute {
  id          String    @id @default(uuid())
  bookingId   String    @unique
  raisedBy    String
  reason      String
  description String?
  resolution  String?
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime  @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("disputes")
  @@schema("public")
}

// ============================================================
// SUBSCRIPTIONS
// ============================================================

model Subscription {
  id            String             @id @default(uuid())
  customerId    String?            @unique
  tradesmanId   String?            @unique
  plan          SubscriptionPlan
  status        SubscriptionStatus @default(ACTIVE)
  startDate     DateTime           @default(now())
  endDate       DateTime
  paymongoSubId String?
  createdAt     DateTime           @default(now())

  customer  CustomerProfile?  @relation(fields: [customerId], references: [id])
  tradesman TradesmanProfile? @relation(fields: [tradesmanId], references: [id])

  @@map("subscriptions")
  @@schema("public")
}

// ============================================================
// REFERRALS
// ============================================================

model ReferralCode {
  id         String   @id @default(uuid())
  customerId String   @unique
  code       String   @unique
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())

  customer  CustomerProfile @relation(fields: [customerId], references: [id])
  referrals Referral[]

  @@map("referral_codes")
  @@schema("public")
}

model Referral {
  id             String   @id @default(uuid())
  referralCodeId String
  referredUserId String
  creditAwarded  Float    @default(200)
  awardedAt      DateTime @default(now())

  referralCode ReferralCode @relation(fields: [referralCodeId], references: [id])

  @@map("referrals")
  @@schema("public")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
  @@schema("public")
}
